{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/api/wallet/apple/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.apple.pkpass" }
      ]
    }
  ]
}
